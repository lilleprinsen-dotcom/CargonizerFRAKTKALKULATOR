{
  "name": "lilleprinsen/cargonizer-woocommerce",
  "description": "Cargonizer connector plugin for WooCommerce",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "^5.26",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Lilleprinsen\\Cargonizer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lilleprinsen\\Cargonizer\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "test:e2e": "phpunit --testsuite e2e",
    "lint:phpstan": "phpstan analyse",
    "lint:psalm": "psalm --no-cache",
    "lint:phpcs": "phpcs"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
