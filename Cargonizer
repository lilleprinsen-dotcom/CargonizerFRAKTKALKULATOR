				'rounding_mode' => isset($pricing_config['rounding_mode']) ? $pricing_config['rounding_mode'] : 'none',
				'base_price' => '',
				'adjusted_price' => '',
				'subtotal_ex_vat' => '',
				'price_incl_vat' => '',
				'rounded_price' => '',
				'final_price_ex_vat' => '',
				'status' => 'failed',
				'http_status' => 0,
				'error' => '',
				'error_code' => '',
				'error_type' => '',
				'error_details' => '',
				'parsed_error_message' => '',
				'human_error' => '',
